# Backend
DATABASE_URL=postgresql+psycopg://cp_user:cp_pass@postgres:5432/cp_db
REDIS_URL=redis://redis:6379/0
SECRET_KEY=changepreneurship-dev-secret
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175

# LLM feature flags
# Enable LLM-generated narratives and recommendations (defaults to false)
USE_LLM=true

# LLM provider settings: groq | openai | azure-openai | anthropic | ollama
LLM_PROVIDER=groq

# Model id per provider (examples):
# - Groq: llama-3.3-70b-versatile, llama-3.1-8b-instant, mixtral-8x7b-32768
# - OpenAI: gpt-4.1-mini, gpt-4.1, o3-mini
# - Azure OpenAI: gpt-4o-mini, gpt-4o
# - Anthropic: claude-3-5-sonnet-202410
# - Ollama: llama3.1:8b
LLM_MODEL=llama-3.3-70b-versatile

# Credentials (use Azure_* for Azure OpenAI)
GROQ_API_KEY=
LLM_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=

# Runtime configuration
LLM_TIMEOUT_SECONDS=60
LLM_MAX_TOKENS=1200
LLM_TEMPERATURE=0.2

# Frontend
VITE_API_BASE=http://localhost:5000
