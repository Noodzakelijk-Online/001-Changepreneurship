# ============================================================
# SIGURNOST: Kopiraj ovaj fajl u .env i popuni prave vrednosti.
# NIKADA ne commit-uj .env u git!
# ============================================================

# --- Database ---
POSTGRES_USER=admin
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=changepreneurship

# --- Redis ---
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
REDIS_PASSWORD=CHANGE_ME_strong_redis_password

# --- Backend (Docker Compose builds DATABASE_URL and REDIS_URL automatski iz gornih vrednosti) ---
# Ne treba rucno menjati ove dve linije osim ako ne pokreces backend van Docker-a:
DATABASE_URL=postgresql://admin:CHANGE_ME_strong_db_password@postgres:5432/changepreneurship
REDIS_URL=redis://:CHANGE_ME_strong_redis_password@redis:6379/0

# --- Flask ---
# Generate: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGE_ME_generate_a_real_secret_key

# --- CORS ---
# Comma-separated list of allowed origins (no trailing slash)
ALLOWED_ORIGINS=http://changepreneurship.duckdns.org,https://changepreneurship.duckdns.org

# --- Admin tools (Caddy basic auth for /redis-ui/) ---
# Generate with: docker run --rm caddy:2-alpine caddy hash-password --plaintext 'yourpassword'
CADDY_ADMIN_HASH=CHANGE_ME_run_caddy_hash_password

# LLM feature flags
# Enable LLM-generated narratives and recommendations (defaults to false)
USE_LLM=true

# LLM provider settings: groq | openai | azure-openai | anthropic | ollama
LLM_PROVIDER=groq

# Model id per provider (examples):
# - Groq: llama-3.3-70b-versatile, llama-3.1-8b-instant, mixtral-8x7b-32768
# - OpenAI: gpt-4.1-mini, gpt-4.1, o3-mini
# - Azure OpenAI: gpt-4o-mini, gpt-4o
# - Anthropic: claude-3-5-sonnet-202410
# - Ollama: llama3.1:8b
LLM_MODEL=llama-3.3-70b-versatile

# Credentials (use Azure_* for Azure OpenAI)
GROQ_API_KEY=
LLM_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=

# Runtime configuration
LLM_TIMEOUT_SECONDS=60
LLM_MAX_TOKENS=1200
LLM_TEMPERATURE=0.2

# Frontend
VITE_API_BASE=http://localhost:5000
