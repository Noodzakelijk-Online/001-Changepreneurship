# ============================================================================
# CHANGEPRENEURSHIP BACKEND - PRODUCTION ENVIRONMENT CONFIGURATION
# ============================================================================
#
# IMPORTANT: This is a template file. Do NOT commit actual secrets to version control.
# Copy this to .env.production and fill in real values.
#
# Usage:
#   1. Copy: cp .env.production.template .env.production
#   2. Fill in actual values (API keys, passwords, etc.)
#   3. Load: export $(cat .env.production | xargs)  # Linux/Mac
#            Get-Content .env.production | ForEach-Object { if ($_ -match '^([^=]+)=(.*)$') { [Environment]::SetEnvironmentVariable($matches[1], $matches[2], 'Process') } }  # Windows PowerShell
#

# ----------------------------------------------------------------------------
# APPLICATION SETTINGS
# ----------------------------------------------------------------------------

# Environment mode (production | development | staging)
FLASK_ENV=production

# Secret key for session encryption (CRITICAL: Generate strong random key)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=REPLACE_WITH_STRONG_SECRET_KEY_MINIMUM_64_CHARACTERS

# ----------------------------------------------------------------------------
# DATABASE CONFIGURATION
# ----------------------------------------------------------------------------

# PostgreSQL (Production recommended)
DATABASE_URL=postgresql+psycopg://username:password@host:5432/database_name

# SQLite (Development/Testing only - NOT recommended for production)
# DATABASE_URL=sqlite:///instance/production.db

# Example cloud database URLs:
# - AWS RDS: postgresql+psycopg://user:pass@rds-instance.region.rds.amazonaws.com:5432/dbname
# - Google Cloud SQL: postgresql+psycopg://user:pass@/dbname?host=/cloudsql/project:region:instance
# - Azure Database: postgresql+psycopg://user%40server:pass@server.postgres.database.azure.com:5432/dbname
# - Render.com: postgresql+psycopg://user:pass@dpg-xxx.oregon-postgres.render.com/dbname

# ----------------------------------------------------------------------------
# REDIS CONFIGURATION
# ----------------------------------------------------------------------------

# Redis for session caching and LLM response caching
REDIS_URL=redis://localhost:6379/0

# Redis with authentication
# REDIS_URL=redis://:password@host:6379/0

# Redis with SSL/TLS (recommended for production)
# REDIS_URL=rediss://default:password@host:6380/0

# Example cloud Redis URLs:
# - AWS ElastiCache: redis://master.xxx.cache.amazonaws.com:6379/0
# - Azure Cache: rediss://:password@xxx.redis.cache.windows.net:6380/0
# - Redis Cloud: redis://default:password@redis-xxxxx.cloud.redislabs.com:12345/0

# ----------------------------------------------------------------------------
# LLM CONFIGURATION
# ----------------------------------------------------------------------------

# Enable LLM features (true | false)
USE_LLM=true

# Enable multi-model consensus (true | false)
LLM_CONSENSUS=true

# Primary LLM Provider (openai | azure-openai | anthropic | ollama)
LLM_PROVIDER=openai

# Primary LLM Model
LLM_MODEL=gpt-4o-mini

# Alternative LLM Provider for consensus (optional)
# LLM_PROVIDER_ALT=anthropic

# Alternative LLM Model for consensus (optional)
# LLM_MODEL_ALT=claude-3-5-sonnet-20241022

# OpenAI API Configuration
OPENAI_API_KEY=sk-proj-REPLACE_WITH_YOUR_OPENAI_API_KEY

# Azure OpenAI Configuration (if using azure-openai provider)
# AZURE_OPENAI_API_KEY=your-azure-key
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com

# Anthropic API Configuration (if using anthropic provider)
# ANTHROPIC_API_KEY=sk-ant-REPLACE_WITH_YOUR_ANTHROPIC_API_KEY

# Ollama Configuration (if using local ollama)
# OLLAMA_HOST=http://localhost:11434

# ----------------------------------------------------------------------------
# CORS CONFIGURATION
# ----------------------------------------------------------------------------

# Allowed origins for CORS (comma-separated)
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Add staging/development origins if needed
# ALLOWED_ORIGINS=https://yourdomain.com,https://staging.yourdomain.com,http://localhost:5173

# ----------------------------------------------------------------------------
# SERVER CONFIGURATION
# ----------------------------------------------------------------------------

# Host to bind (0.0.0.0 for all interfaces, 127.0.0.1 for localhost only)
HOST=0.0.0.0

# Port to listen on
PORT=5000

# Gunicorn workers (Linux/Docker) - Recommended: (2 * CPU cores) + 1
GUNICORN_WORKERS=5

# Waitress threads (Windows) - Recommended: 8-16
WAITRESS_THREADS=8

# Log level (debug | info | warning | error | critical)
LOG_LEVEL=info

# ----------------------------------------------------------------------------
# SSL/TLS CONFIGURATION (Optional - usually handled by reverse proxy)
# ----------------------------------------------------------------------------

# SSL enabled (true | false)
# SSL_ENABLED=true

# SSL certificate and key paths
# SSL_CERTFILE=/path/to/cert.pem
# SSL_KEYFILE=/path/to/key.pem

# ----------------------------------------------------------------------------
# MONITORING & LOGGING (Optional)
# ----------------------------------------------------------------------------

# Sentry DSN for error tracking
# SENTRY_DSN=https://xxx@sentry.io/xxx

# Application Insights instrumentation key (Azure)
# APPINSIGHTS_INSTRUMENTATION_KEY=your-key

# ----------------------------------------------------------------------------
# RATE LIMITING (Optional - recommended for production)
# ----------------------------------------------------------------------------

# Enable rate limiting (true | false)
# RATE_LIMIT_ENABLED=true

# Rate limit: requests per minute per IP
# RATE_LIMIT_PER_MINUTE=60

# ----------------------------------------------------------------------------
# BACKUP & MAINTENANCE (Optional)
# ----------------------------------------------------------------------------

# Database backup schedule (cron format)
# BACKUP_SCHEDULE=0 2 * * *  # 2 AM daily

# Backup retention days
# BACKUP_RETENTION_DAYS=7

# ----------------------------------------------------------------------------
# FEATURE FLAGS (Optional)
# ----------------------------------------------------------------------------

# Enable new features for testing
# FEATURE_ADVANCED_ANALYTICS=false
# FEATURE_EMAIL_NOTIFICATIONS=false

# ============================================================================
# END OF CONFIGURATION
# ============================================================================
